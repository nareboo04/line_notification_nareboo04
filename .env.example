# LINE Bot
LINE_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# MySQL
MYSQL_ROOT_PASSWORD=change_me_use_strong_password
MYSQL_DATABASE=users_db

# App settings
ALERT_CHECK_INTERVAL=300   # price check every N seconds (default 5 min)
DAILY_REPORT_HOUR=18       # send daily gold report at this hour (24h, Bangkok time)

# Ports (change if conflicts with other services)
API_PORT=5000
PMA_PORT=8080              # phpMyAdmin — only available with: docker compose --profile dev up
